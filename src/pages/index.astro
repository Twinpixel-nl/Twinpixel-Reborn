const reviews = [
  {
    text: "TwinPixel heeft mijn verwachtingen overtroffen. Prachtige website opgeleverd binnen een week! De website is snel, gebruiksvriendelijk en ziet er fantastisch uit.",
    author: "Harvey Meurs",
    company: "Eigenaar, Wetvanstaal",
  },
  {
    text: "Nieuwe website laten maken en geweldig geholpen. Niks is teveel en alles wordt snel aangepast. Ze denken goed mee en geven eerlijke adviezen. Top samenwerking!",
    author: "Otto Vleeming",
    company: "Stadspartij Wageningen",
  },
