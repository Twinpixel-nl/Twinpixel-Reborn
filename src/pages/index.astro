  image: "https://twinpixel.nl/og-image.jpg",
  email: "info@twinpixel.nl",
  areaServed: [
    "Wageningen",
    "Ede",
    "Bennekom",
    "Rhenen",
    "Foodvalley",
  ],
  address: {
    "@type": "PostalAddress",
    addressLocality: "Wageningen",
    addressCountry: "NL",
  },
  sameAs: [mapsUrl],
  description:
    "TwinPixel is een webdesign bureau in Wageningen. Wij ontwerpen en ontwikkelen snelle websites en maatwerk tools met focus op positionering, conversie en SEO.",
