  <script>
    let tick = false;

    window.addEventListener("mousemove", (e) => {
      if (tick) return;
      tick = true;

      requestAnimationFrame(() => {
        const me = /** @type {MouseEvent} */ (e);
        const x = (me.clientX / window.innerWidth) * 100;
        const y = (me.clientY / window.innerHeight) * 100;

        document.documentElement.style.setProperty("--mouse-x", `${x}%`);
        document.documentElement.style.setProperty("--mouse-y", `${y}%`);

        tick = false;
      });
    });

    const mags = document.querySelectorAll(".mag");

    mags.forEach((node) => {
      if (!(node instanceof HTMLElement)) return;
      const el = node;

      let rect = el.getBoundingClientRect();
      const updateRect = () => (rect = el.getBoundingClientRect());

      window.addEventListener("resize", updateRect);
      el.addEventListener("mouseenter", updateRect);

      el.addEventListener("mousemove", (e) => {
        requestAnimationFrame(() => {
          const me = /** @type {MouseEvent} */ (e);
          const x = me.clientX - rect.left - rect.width / 2;
          const y = me.clientY - rect.top - rect.height / 2;

          el.style.transform = `translate(${x * 0.3}px, ${y * 0.3}px)`;
        });
      });

      el.addEventListener("mouseleave", () => {
        requestAnimationFrame(() => {
          el.style.transform = "translate(0px, 0px)";
        });
      });
    });
  </script>

