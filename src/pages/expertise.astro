---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import { expertiseItems } from "../data/expertise";
---

<BaseLayout
  title="Twinpixel | Expertise"
  description="Drie kerngebieden. Kies je expertise en bekijk aanpak, deliverables en resultaat."
>
  <!-- Hero Section -->
  <section class="hero">
    <div class="container hero-inner">
      <p class="kicker fade-item" style="animation-delay: 0.1s">Onze Expertise</p>
      <h1 class="h1 fade-item" style="animation-delay: 0.2s">Drie routes naar succes</h1>
      <p class="lead fade-item" style="animation-delay: 0.3s">
        We bouwen websites die werken. Kies één of combineer meerdere expertises
        voor een complete digitale oplossing. Branding als fundament, websites als kracht.
      </p>
    </div>
  </section>

  <!-- Expertise Cards -->
  <section class="section expertise-section">
    <div class="container">
      <div class="expertise-intro">
        <p class="expertise-note">
          <strong>Kies je expertise:</strong> Start met een website als basis, voeg branding toe voor een complete merkbeleving.
          Of neem contact op voor advies over de beste combinatie.
        </p>
      </div>

      <div class="expertise-grid">
        {expertiseItems.map((item) => (
          <a
            class="expertise-card"
            href={`/expertise/${item.slug}`}
            style={`--accent: ${item.accent};`}
            aria-label={`Bekijk ${item.title} expertise`}
          >
            <div class="card-header">
              <div class="card-badge" style={`background: ${item.accent}20; color: ${item.accent};`}>
                {item.title}
              </div>
              <div class="card-icon" style={`background: ${item.accent}15;`}>
                <div class="icon-placeholder" style={`background: ${item.accent};`}></div>
              </div>
            </div>

            <div class="card-content">
              <p class="card-description">{item.intro}</p>

              <div class="card-features">
                <div class="feature-group">
                  <h4 class="feature-title">Wat je krijgt</h4>
                  <ul class="feature-list">
                    {item.whatYouGet.slice(0, 2).map((feature) => (
                      <li>{feature}</li>
                    ))}
                  </ul>
                </div>

                <div class="feature-group">
                  <h4 class="feature-title">Aanpak</h4>
                  <ul class="feature-list numbered">
                    {item.steps.slice(0, 2).map((step) => (
                      <li>
                        <span class="step-number">{step.nr}</span>
                        <span>{step.text}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>

            <div class="card-footer">
              <div class="card-results">
                {item.panel.slice(0, 2).map((panel) => (
                  <div class="result-item">
                    <span class="result-label">{panel.label}:</span>
                    <span class="result-value">{panel.value}</span>
                  </div>
                ))}
              </div>
              <div class="card-cta">
                <span class="cta-text">Bekijk details</span>
                <div class="cta-arrow">→</div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Onderhoud / Doorontwikkeling -->
  <section class="section maintenance-section" aria-label="Onderhoud en doorontwikkeling">
    <div class="container">
      <div class="maintenance-bar">
        <div class="maintenance-left">
          <p class="kicker">Onderhoud</p>
          <h2 class="maintenance-title">Onderhoud & doorontwikkeling</h2>
          <p class="maintenance-desc">
            Je site blijft snel, veilig en up-to-date. Inclusief hosting, monitoring, updates en kleine verbeteringen.
          </p>

          <div class="maintenance-points">
            <span class="mp">Hosting & updates</span>
            <span class="mp">Monitoring & security</span>
            <span class="mp">Tot 1 uur aanpassingen p/m</span>
            <span class="mp">Extra uren: €50/u</span>
          </div>
        </div>

        <div class="maintenance-right" aria-label="Prijs en acties">
          <div class="maintenance-price">
            <span class="price-label">Vanaf</span>
            <span class="price-amount">€20</span>
            <span class="price-period">/ maand</span>
          </div>

          <div class="maintenance-actions">
            <Button href="/contact" variant="primary" label="Plan kennismaking" />
            <Button href="/contact" variant="secondary" label="Vraag prijsindicatie" />
          </div>

          <p class="maintenance-note">
            Aan te raden na oplevering voor performance, veiligheid en kleine iteraties.
          </p>
        </div>
      </div>
    </div>
  </section>


 <style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .fade-item {
    opacity: 0;
    animation: fadeInUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  /* Hero Section */
  .hero {
    padding: 140px 0 80px;
    position: relative;
    overflow: hidden;
    background: radial-gradient(120% 140% at 20% 0%, rgba(47, 137, 255, 0.18), transparent 60%);
  }

  .hero::after {
    content: "";
    position: absolute;
    inset: -200px -120px;
    pointer-events: none;
    background:
      radial-gradient(1000px 620px at 20% 0%, rgba(47, 137, 255, 0.2), transparent 62%),
      radial-gradient(900px 620px at 85% 35%, rgba(124, 58, 237, 0.12), transparent 68%),
      radial-gradient(900px 620px at 80% 80%, rgba(20, 184, 166, 0.08), transparent 70%);
    opacity: 0.9;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 800px;
  }

  .kicker {
    margin: 0 0 14px;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
  }

  .h1 {
    margin: 0;
    font-size: clamp(44px, 5.2vw, 74px);
    letter-spacing: -0.05em;
    line-height: 1.02;
    font-weight: 650;
  }

  .lead {
    margin: 18px 0 0;
    color: rgba(255, 255, 255, 0.7);
    font-size: 18px;
    line-height: 1.8;
    max-width: 70ch;
  }

  /* Expertise Section */
  .expertise-section {
    padding: 80px 0;
  }

  .expertise-intro {
    text-align: center;
    margin-bottom: 48px;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .expertise-note {
    font-size: 16px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.78);
    margin: 0;
  }

  .expertise-note strong {
    color: rgba(255, 255, 255, 0.92);
    font-weight: 600;
  }

  .expertise-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 1300px;
    margin: 0 auto;
  }

  .expertise-card {
    display: flex;
    flex-direction: column;
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.025);
    padding: 32px;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    min-height: 560px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
  }

  .expertise-card::before {
    content: "";
    position: absolute;
    inset: -200px -120px;
    pointer-events: none;
    opacity: 0;
    background: radial-gradient(
      600px 400px at 30% 20%,
      color-mix(in srgb, var(--accent) 15%, transparent),
      transparent 70%
    );
    transition: opacity 0.3s ease;
  }

  .expertise-card:hover {
    transform: translateY(-8px);
    border-color: color-mix(in srgb, var(--accent) 30%, rgba(255, 255, 255, 0.14));
    background: rgba(255, 255, 255, 0.035);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.18);
  }

  .expertise-card:hover::before {
    opacity: 1;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 24px;
    min-height: 56px;
  }

  .card-badge {
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.02em;
    border: 1px solid color-mix(in srgb, var(--accent) 20%, rgba(255, 255, 255, 0.12));
  }

  .card-icon {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .icon-placeholder {
    width: 24px;
    height: 24px;
    border-radius: 6px;
  }

  .card-content {
    display: flex;
    flex-direction: column;
    flex: 1;
    margin-bottom: 24px;
  }

  .card-description {
    margin: 0 0 24px;
    color: rgba(255, 255, 255, 0.78);
    font-size: 16px;
    line-height: 1.7;
    min-height: 120px;
  }

  .card-features {
    display: grid;
    gap: 20px;
  }

  .feature-group {
    display: grid;
    gap: 12px;
  }

  .feature-title {
    margin: 0;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    font-weight: 600;
  }

  .feature-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 10px;
  }

  .feature-list li {
    color: rgba(255, 255, 255, 0.76);
    font-size: 14px;
    line-height: 1.55;
    display: flex;
    align-items: flex-start;
    gap: 8px;
  }

  .feature-list.numbered li {
    position: relative;
    padding-left: 24px;
  }

  .step-number {
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    min-width: 20px;
  }

  .card-footer {
    margin-top: auto;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 16px;
    align-items: end;
  }

  .card-results {
    display: grid;
    gap: 10px;
  }

  .result-item {
    display: grid;
    gap: 3px;
  }

  .result-label {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.48);
  }

  .result-value {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.45;
    max-width: 26ch;
  }

  .card-cta {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--accent);
    font-weight: 600;
    font-size: 14px;
    transition: gap 0.3s ease;
    align-self: end;
  }

  .expertise-card:hover .card-cta {
    gap: 12px;
  }

  .cta-arrow {
    transition: transform 0.3s ease;
  }

  .expertise-card:hover .cta-arrow {
    transform: translateX(4px);
  }

  /* Maintenance Bar */
  .maintenance-section {
    padding: 0 0 80px;
  }

  .maintenance-bar {
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.025);
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.12);
    padding: 34px;
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1.25fr 0.75fr;
    gap: 28px;
    align-items: center;
    max-width: 1300px;
    margin: 0 auto;
  }

  .maintenance-bar::before {
    content: "";
    position: absolute;
    inset: -200px -160px;
    pointer-events: none;
    opacity: 0.9;
    background:
      radial-gradient(900px 520px at 12% 0%, rgba(47, 137, 255, 0.18), transparent 62%),
      radial-gradient(900px 520px at 92% 35%, rgba(124, 58, 237, 0.12), transparent 68%),
      radial-gradient(900px 520px at 70% 120%, rgba(34, 197, 94, 0.1), transparent 70%);
  }

  .maintenance-left,
  .maintenance-right {
    position: relative;
    z-index: 1;
  }

  .maintenance-title {
    margin: 8px 0 10px;
    font-size: 26px;
    letter-spacing: -0.03em;
    line-height: 1.1;
    font-weight: 650;
  }

  .maintenance-desc {
    margin: 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: 16px;
    line-height: 1.7;
    max-width: 70ch;
  }

  .maintenance-points {
    margin-top: 18px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .mp {
    font-size: 12px;
    padding: 7px 10px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(0, 0, 0, 0.1);
    color: rgba(255, 255, 255, 0.74);
    white-space: nowrap;
  }

  .maintenance-price {
    display: flex;
    align-items: baseline;
    justify-content: flex-end;
    gap: 8px;
    margin-bottom: 14px;
  }

  .price-label {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
  }

  .price-amount {
    font-size: 44px;
    letter-spacing: -0.04em;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.92);
  }

  .price-period {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.65);
  }

  .maintenance-actions {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    flex-wrap: wrap;
  }

  .maintenance-note {
    margin: 14px 0 0;
    text-align: right;
    color: rgba(255, 255, 255, 0.6);
    font-size: 13px;
    line-height: 1.6;
    max-width: 40ch;
    margin-left: auto;
  }

  /* Responsive */
  @media (max-width: 980px) {
    .hero {
      padding: 100px 0 60px;
    }

    .expertise-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .expertise-card {
      padding: 24px;
      min-height: auto;
    }

    .card-description {
      min-height: auto;
    }

    .card-footer {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .maintenance-section {
      padding: 0 0 70px;
    }

    .maintenance-bar {
      grid-template-columns: 1fr;
      padding: 28px 22px;
    }

    .maintenance-price {
      justify-content: flex-start;
    }

    .maintenance-actions {
      justify-content: flex-start;
    }

    .maintenance-note {
      text-align: left;
      margin-left: 0;
      max-width: none;
    }
  }

  @media (max-width: 640px) {
    .expertise-card {
      padding: 20px;
    }

    .card-header {
      margin-bottom: 20px;
    }

    .card-content {
      margin-bottom: 20px;
    }

    .card-features {
      gap: 16px;
    }

    .maintenance-bar {
      padding: 24px 18px;
    }

    .price-amount {
      font-size: 38px;
    }
  }
</style>
</BaseLayout>