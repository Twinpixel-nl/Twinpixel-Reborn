---
import BaseLayout from "../layouts/BaseLayout.astro";
import CasesPreview from "../components/CasesPreview.astro";
import Button from "../components/Button.astro";
import { Image } from "astro:assets";
import WijsFoto from "../assets/person/website-laten-maken-wageningen.webp";

// Consistent met je footer-link
const mapsUrl = "https://maps.app.goo.gl/XJkGA7g8TkB1aJTA6";

const page = {
  title: "Website laten maken Wageningen | Kosten & Werkwijze | TwinPixel",
  description:
    "Wil je een professionele website laten maken in Wageningen? TwinPixel ontwerpt snelle, SEO-vriendelijke websites die zorgen voor meer aanvragen. Bekijk onze tarieven!",
  h1: "Website laten maken in Wageningen",
};

const business = {
  name: "TwinPixel",
  email: "info@twinpixel.nl",
  phone: "+31 6 82579179",
  addressLocality: "Wageningen",
  addressRegion: "Gelderland",
  addressCountry: "NL",
  area: ["Wageningen", "Ede", "Bennekom", "Rhenen", "Veenendaal"],
};

const investments = [
  {
    title: "Website Launch",
    price: "€2.450 – €3.750",
    points: ["Design & maatwerk ontwikkeling", "SEO-structuur & performance basis", "Conversiegerichte flow naar aanvraag"],
    note: "Meest gekozen voor ondernemers die vooral meer aanvragen willen.",
  },
  {
    title: "Technical Build",
    price: "€4.900 – €12.000",
    points: ["Maatwerk frontend of tool", "API- & systeemkoppelingen", "Faseerbaar: discovery → build → grow"],
    note: "Voor platformen, tooling en complexere wensen.",
  },
];

const reviews = [
  {
    author: "Harvey Meurs",
    company: "Wetvanstaal",
    text: "Prachtige website opgeleverd binnen een week. Snel, gebruiksvriendelijk en ziet er fantastisch uit.",
  },
  {
    author: "Otto Vleeming",
    company: "Stadspartij Wageningen",
    text: "Ze denken goed mee en geven eerlijke adviezen. Top samenwerking!",
  },
  {
    author: "Julian van Beek",
    company: "Rocket Agency",
    text: "Snelle levering, goede service, hoge kwaliteit en persoonlijke aanpak.",
  },
];

const faqs = [
  {
    q: "Wat kost een website laten maken in Wageningen?",
    a: "Meestal valt dit in de range van een Website Launch-traject (€2.450–€3.750). De exacte prijs hangt af van het aantal pagina’s, content en eventuele koppelingen.",
  },
  {
    q: "Hoe lang duurt het bouwen van een website?",
    a: "Meestal 3 tot 5 weken. Het tempo hangt vooral af van hoe snel feedback rondes lopen en of content al klaar ligt.",
  },
  {
    q: "Kunnen jullie ook helpen met vindbaarheid (SEO)?",
    a: "Ja. We bouwen een sterke technische basis en helpen met content die past bij de lokale zoekintentie in Wageningen.",
  },
  {
    q: "Kunnen we ook in Wageningen afspreken?",
    a: "Ja. We zitten in Wageningen, dus even sparren op locatie kan altijd op afspraak.",
  },
];

const origin = (Astro.site ?? Astro.url.origin).toString();
const canonicalURL = new URL(Astro.url.pathname, origin).toString();
const orgId = `${origin}#organization`;
const areaServed = business.area.map((name) => ({ "@type": "City", name }));

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: origin },
      { "@type": "ListItem", position: 2, name: "Website laten maken in Wageningen", item: canonicalURL },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": `${canonicalURL}#service`,
    name: "Website laten maken in Wageningen",
    serviceType: ["Webdesign", "Webdevelopment", "SEO"],
    provider: { "@id": orgId },
    areaServed,
    url: canonicalURL,
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  },
];
---

<BaseLayout 
  title={page.title} 
  description={page.description} 
  schema={jsonLd}
>
  <main>
    <!-- HERO SPLIT -->
    <section class="hero-split">
      <div class="container hero-grid">
        <div class="hero-text-side">
          <p class="kicker">Webdesign & Development</p>
          <h1 class="h1">{page.h1}</h1>
          <p class="lead">
            {business.name} ontwerpt en bouwt high-end websites die vertrouwen wekken, razendsnel laden
            en gericht zijn op meer aanvragen voor ondernemers in Wageningen.
          </p>
          <div class="cta">
            <Button href="/contact" variant="primary" label="Plan kennismaking" />
            <Button href="#cases" variant="secondary" label="Bekijk ons werk" />
          </div>
          <div class="proof" aria-label="Key points">
            <span>Premium uitstraling</span>
            <span class="sep">/</span>
            <span>SEO-proof</span>
            <span class="sep">/</span>
            <span>Maatwerk</span>
          </div>
        </div>

        <div class="hero-image-side">
          <div class="image-frame">
<Image
  src={WijsFoto}
  alt="Team TwinPixel overlegt over het laten maken van een website in Wageningen"
  class="hero-img"
  widths={[400, 800, 1200]}
  sizes="(max-width: 1024px) 100vw, 45vw"
  loading="eager"
  priority
  format="webp"
/>
            <div class="image-overlay"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- INTRO MET INTERNE LINK NAAR HOMEPAGE -->
    <section class="section">
      <div class="container">
        <h2 class="h2">Webdesign bureau in Wageningen</h2>
        <p class="lead small">
          TwinPixel is hét bureau voor ondernemers die online willen groeien. Als specialist in 
          <a class="inline-link" href="/">webdesign in Wageningen</a> kijken we verder dan alleen een mooi plaatje; we bouwen digitale fundamenten die resultaat opleveren.
        </p>
        <p class="text">
          Of je nu een nieuwe website wilt laten maken of je huidige platform wilt professionaliseren: wij denken strategisch met je mee over positionering, conversie en techniek.
        </p>
        <div class="chips">
          {business.area.map((c) => <span class="chip">{c}</span>)}
        </div>
      </div>
    </section>

    <!-- DIENSTEN -->
    <section class="section" id="diensten">
      <div class="container">
        <h2 class="h2">Wat je krijgt</h2>
        <div class="pillars">
          <div class="pill">
            <h3 class="pill-title">Website laten maken</h3>
            <p class="pill-text">Een compleet traject van strategie naar design tot een vlekkeloze livegang van je nieuwe website.</p>
          </div>
          <div class="pill">
            <h3 class="pill-title">Conversiegericht Design</h3>
            <p class="pill-text">Design dat niet alleen mooi is, maar bezoekers ook daadwerkelijk overtuigt om contact met je op te nemen.</p>
          </div>
          <div class="pill">
            <h3 class="pill-title">Technische SEO-basis</h3>
            <p class="pill-text">Een razendsnelle website met een structuur die zoekmachines zoals Google direct begrijpen en waarderen.</p>
          </div>
          <div class="pill">
            <h3 class="pill-title">Lokale Expertise</h3>
            <p class="pill-text">Wij kennen de regio Wageningen en Foodvalley en weten hoe we jouw bedrijf hier lokaal op de kaart zetten.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- KOSTEN -->
    <section class="section costs" id="kosten">
      <div class="container">
        <div class="section-head">
          <h2 class="h2">Investering</h2>
          <p class="lead small">Heldere prijzen voor een professionele website in Wageningen.</p>
        </div>
        <div class="costs-grid">
          {investments.map((p) => (
            <div class="cost-card">
              <div class="cost-top">
                <span class="cost-title">{p.title}</span>
                <span class="cost-price">{p.price}</span>
              </div>
              <ul class="cost-list">
                {p.points.map((x) => <li>{x}</li>)}
              </ul>
              <p class="cost-note">{p.note}</p>
              <div class="cost-actions">
                <Button href="/contact" variant="primary" label="Vraag voorstel aan" />
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- PORTFOLIO -->
    <section class="section" id="cases">
      <div class="container">
        <h2 class="h2">Recent werk</h2>
      </div>
      <CasesPreview />
    </section>

    <!-- REVIEWS -->
    <section class="section reviews">
      <div class="container">
        <h2 class="h2 center">Klantervaringen</h2>
        <div class="reviews-grid">
          {reviews.map((r) => (
            <div class="review-card">
              <div class="review-stars">★★★★★</div>
              <p class="review-text">"{r.text}"</p>
              <div class="review-author">
                <span class="author-name">{r.author}</span>
                <span class="author-company">{r.company}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section faq" id="faq">
      <div class="container">
        <h2 class="h2">Veelgestelde vragen</h2>
        <div class="faq-wrap">
          {faqs.map((f) => (
            <details class="faq-item">
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CONTACT -->
    <section class="section">
      <div class="container">
        <div class="cta-box">
          <div>
            <h2 class="h2">Samenwerken met TwinPixel?</h2>
            <p class="lead small">Laten we bespreken hoe we jouw website naar het volgende niveau tillen.</p>
          </div>
          <Button href="/contact" variant="primary" label="Start jouw project" />
        </div>
      </div>
    </section>
  </main>

  <style>
    /* Algemene stijlen */
    .section { padding: 80px 0; }
    .container { width: min(1100px, calc(100% - 2rem)); margin: 0 auto; }
    .center { text-align: center; }
    .kicker { text-transform: uppercase; font-size: 12px; letter-spacing: .12em; color: var(--muted); }
    .h1 { font-size: clamp(36px, 5vw, 60px); font-weight: 700; letter-spacing: -0.04em; line-height: 1.1; margin: 10px 0; }
    .h2 { font-size: clamp(26px, 3.5vw, 40px); font-weight: 600; letter-spacing: -0.02em; }
    .lead { font-size: 18px; color: var(--muted); line-height: 1.7; margin-top: 20px; max-width: 60ch; }
    .lead.small { font-size: 16px; margin-top: 12px; }
    .text { color: var(--muted2); line-height: 1.8; margin-top: 15px; max-width: 70ch; }
    .inline-link { color: var(--brand); border-bottom: 1px solid rgba(47,137,255,0.3); transition: 0.2s; text-decoration: none; }
    .inline-link:hover { border-bottom-color: var(--brand); }

    /* Hero Split */
    .hero-split { padding: clamp(120px, 12vh, 160px) 0 80px; overflow: hidden; }
    .hero-grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 60px; align-items: center; }
    .image-frame { position: relative; border-radius: 28px; overflow: hidden; border: 1px solid var(--stroke); box-shadow: 0 30px 60px -12px rgba(0,0,0,0.5); aspect-ratio: 4/3; }
    .hero-img { width: 100%; height: 100%; object-fit: cover; }
    .image-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, transparent 60%, var(--bg) 100%); opacity: 0.6; }
    .cta { margin-top: 30px; display: flex; gap: 15px; flex-wrap: wrap; }
    .proof { margin-top: 25px; display: flex; gap: 15px; color: var(--muted2); font-size: 13px; font-weight: 500; }
    .sep { opacity: 0.3; }

    /* UI Elementen */
    .chips { display: flex; gap: 10px; margin-top: 20px; flex-wrap: wrap; }
    .chip { padding: 6px 12px; border-radius: 99px; background: var(--card); border: 1px solid var(--stroke); font-size: 12px; }
    .pillars { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 35px; }
    .pill { padding: 30px; background: var(--card); border: 1px solid var(--stroke); border-radius: 20px; }
    .pill-title { font-size: 18px; font-weight: 600; margin-bottom: 12px; color: #fff; }
    .pill-text { font-size: 14px; color: var(--muted); line-height: 1.6; }

    /* Kosten */
    .costs-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 35px; }
    .cost-card { padding: 35px; background: var(--card); border: 1px solid var(--stroke); border-radius: 24px; display: flex; flex-direction: column; }
    .cost-top { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 25px; border-bottom: 1px solid var(--stroke); padding-bottom: 20px; }
    .cost-title { font-size: 20px; font-weight: 700; color: #fff; }
    .cost-price { font-size: 18px; color: var(--brand); font-weight: 600; }
    .cost-list { list-style: none; padding: 0; margin: 0 0 25px 0; display: grid; gap: 12px; }
    .cost-list li { font-size: 14px; color: var(--muted); padding-left: 24px; position: relative; }
    .cost-list li::before { content: "→"; position: absolute; left: 0; color: var(--brand); font-weight: bold; }
    .cost-note { font-size: 13px; color: var(--muted2); margin-top: auto; padding-top: 20px; font-style: italic; margin-bottom: 20px; }

    /* Reviews */
    .reviews-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 45px; }
    .review-card { padding: 30px; background: var(--card); border: 1px solid var(--stroke); border-radius: 20px; }
    .review-stars { color: #fbbf24; margin-bottom: 15px; font-size: 14px; }
    .review-text { font-style: italic; font-size: 15px; color: var(--text); line-height: 1.6; margin-bottom: 25px; }
    .author-name { display: block; font-weight: 650; color: #fff; font-size: 15px; }
    .author-company { font-size: 12px; color: var(--muted2); margin-top: 4px; display: block; }

    /* FAQ */
    .faq-wrap { margin-top: 35px; display: grid; gap: 15px; }
    .faq-item { background: var(--card); border: 1px solid var(--stroke); border-radius: 16px; transition: 0.3s; }
    .faq-item summary { padding: 20px 25px; cursor: pointer; font-weight: 600; color: #fff; list-style: none; display: flex; justify-content: space-between; align-items: center; }
    .faq-item summary::-webkit-details-marker { display: none; }
    .faq-item summary::after { content: '↓'; font-size: 12px; opacity: 0.5; }
    .faq-item[open] summary::after { content: '↑'; }
    .faq-item p { padding: 0 25px 25px 25px; color: var(--muted); font-size: 15px; line-height: 1.7; }

    /* CTA Box */
    .cta-box { padding: 50px; background: rgba(47,137,255,0.05); border: 1px solid var(--brand); border-radius: 32px; display: flex; justify-content: space-between; align-items: center; gap: 30px; }

    /* Responsiviteit */
    @media (max-width: 1024px) {
      .hero-grid { grid-template-columns: 1fr; text-align: center; gap: 50px; }
      .hero-text-side { display: flex; flex-direction: column; align-items: center; }
      .hero-image-side { order: -1; max-width: 600px; margin: 0 auto; }
      .cta, .proof { justify-content: center; }
      .reviews-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 768px) {
      .pillars, .costs-grid { grid-template-columns: 1fr; }
      .cta-box { flex-direction: column; text-align: center; padding: 40px 30px; }
      .section { padding: 60px 0; }
    }
  </style>
</BaseLayout>