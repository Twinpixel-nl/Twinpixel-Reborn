---
import BaseLayout from "../layouts/BaseLayout.astro";
import CasesPreview from "../components/CasesPreview.astro";
import Button from "../components/Button.astro";

// Consistent met je footer-link en makkelijk te vervangen als nodig
const mapsUrl = "https://maps.app.goo.gl/XJkGA7g8TkB1aJTA6";

const page = {
  title: "Website laten maken Wageningen | Kosten & Werkwijze | TwinPixel",
  description:
    "Wil je een professionele website laten maken in Wageningen? TwinPixel ontwerpt snelle, SEO-vriendelijke websites die zorgen voor meer aanvragen. Bekijk onze tarieven!",
  h1: "Website laten maken in Wageningen",
};

const business = {
  name: "TwinPixel",
  email: "info@twinpixel.nl",
  phone: "+31 6 82579179",
  addressLocality: "Wageningen",
  addressRegion: "Gelderland",
  addressCountry: "NL",
  area: ["Wageningen", "Ede", "Bennekom", "Rhenen", "Veenendaal"],
};

const investments = [
  {
    title: "Website Launch",
    price: "€2.450 – €3.750",
    points: ["Design & maatwerk ontwikkeling", "SEO-structuur & performance basis", "Conversiegerichte flow naar aanvraag"],
    note: "Meest gekozen voor ondernemers die vooral meer aanvragen willen.",
  },
  {
    title: "Technical Build",
    price: "€4.900 – €12.000",
    points: ["Maatwerk frontend of tool", "API- & systeemkoppelingen", "Faseerbaar: discovery → build → grow"],
    note: "Voor platformen, tooling en complexere wensen.",
  },
];

const reviews = [
  {
    author: "Harvey Meurs",
    company: "Wetvanstaal",
    text:
      "Prachtige website opgeleverd binnen een week. Snel, gebruiksvriendelijk en ziet er fantastisch uit.",
  },
  {
    author: "Otto Vleeming",
    company: "Stadspartij Wageningen",
    text: "Ze denken goed mee en geven eerlijke adviezen. Top samenwerking!",
  },
  {
    author: "Julian van Beek",
    company: "Rocket Agency",
    text: "Snelle levering, goede service, hoge kwaliteit en persoonlijke aanpak.",
  },
];

const proof = [
  {
    title: "By Britt Nails",
    text:
      "Lokale vindbaarheid als uitgangspunt: heldere structuur, snelle pagina’s en een verhaal dat direct naar contact stuurt.",
    href: "/cases",
  },
  {
    title: "VVD Wageningen",
    text:
      "Autoriteit en performance: een strakke site die op mobiel net zo overtuigt als op desktop.",
    href: "/cases",
  },
];

const faqs = [
  {
    q: "Wat kost een website laten maken in Wageningen?",
    a: "Meestal valt dit in de range van een Website Launch-traject (€2.450–€3.750). De exacte prijs hangt af van het aantal pagina’s, content (tekst/beelden) en eventuele koppelingen.",
  },
  {
    q: "Hoe lang duurt het bouwen van een website?",
    a: "Meestal 3 tot 5 weken. Het tempo hangt vooral af van hoe snel feedback rondes lopen en of content (tekst/beelden) al klaar ligt.",
  },
  {
    q: "Kunnen jullie ook helpen met vindbaarheid (SEO)?",
    a: "Ja. We bouwen een sterke technische basis (structuur, headings, indexeerbaarheid, performance) en helpen met content die past bij lokale zoekintentie.",
  },
  {
    q: "Kunnen we ook in Wageningen afspreken?",
    a: "Ja. We zitten in Wageningen, dus even sparren op locatie kan op afspraak.",
  },
];

const origin = (Astro.site ?? Astro.url.origin).toString();
const canonicalURL = new URL(Astro.url.pathname, origin).toString();
const orgId = `${origin}#organization`;
const areaServed = business.area.map((name) => ({ "@type": "City", name }));

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: origin },
      { "@type": "ListItem", position: 2, name: "Website laten maken in Wageningen", item: canonicalURL },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${canonicalURL}#webpage`,
    url: canonicalURL,
    name: page.h1,
    description: page.description,
    inLanguage: "nl-NL",
    about: { "@id": orgId },
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": `${canonicalURL}#service`,
    name: "Website laten maken in Wageningen",
    serviceType: ["Webdesign", "Webdevelopment", "SEO"],
    provider: { "@id": orgId },
    areaServed,
    url: canonicalURL,
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: {
        "@type": "Answer",
        text: f.a,
      },
    })),
  },
];
---

<BaseLayout 
  title={page.title} 
  description={page.description} 
  schema={jsonLd}
>
  <main>
    <!-- HERO -->
    <section class="section hero-simple" aria-label="Website laten maken Wageningen">
      <div class="container">
        <p class="kicker">Webdesign & Development</p>
        <h1 class="h1">{page.h1}</h1>
        <p class="lead">
          Op zoek naar een professionele website voor je bedrijf in Wageningen?
          <strong> {business.name}</strong> ontwerpt en bouwt websites die vertrouwen wekken, snel laden
          en gericht zijn op meer aanvragen.
        </p>
        <div class="cta">
          <Button href="/contact" variant="primary" label="Plan kennismaking" />
          <Button href="#cases" variant="secondary" label="Bekijk ons werk" />
        </div>
        <div class="proof" aria-label="Key points">
          <span>Premium uitstraling</span>
          <span class="sep">/</span>
          <span>Logische structuur</span>
          <span class="sep">/</span>
          <span>Vindbaar in Google</span>
        </div>
      </div>
    </section>

    <!-- INTRO MET STRATEGISCHE INTERNE LINK -->
    <section class="section" aria-label="Webdesign bureau Wageningen">
      <div class="container">
        <h2 class="h2">Webdesign bureau in Wageningen</h2>
        <p class="lead small">
          {business.name} is een bureau voor ondernemers die resultaat willen. Als specialist in 
          <a class="inline-link" href="/">webdesign in Wageningen</a> bouwen wij websites die niet alleen 
          mooi ogen, maar ook technisch perfect functioneren.
        </p>
        <p class="text">
          Of je nu een compleet nieuwe website wilt laten maken of je huidige online positie wilt verbeteren: 
          wij denken strategisch met je mee. Geen standaard templates, maar maatwerk dat past bij jouw merk.
        </p>
        <div class="chips" aria-label="Regio">
          {business.area.map((c) => <span class="chip">{c}</span>)}
        </div>
      </div>
    </section>

    <!-- WHAT YOU GET -->
    <section class="section" aria-label="Diensten" id="diensten">
      <div class="container">
        <h2 class="h2">Wat we doen</h2>
        <div class="pillars" aria-label="Kernpunten">
          <div class="pill">
            <h3 class="pill-title">Website laten maken</h3>
            <p class="pill-text">Van eerste concept tot de livegang. Wij regelen het volledige traject voor jouw nieuwe platform.</p>
          </div>
          <div class="pill">
            <h3 class="pill-title">Conversie & Design</h3>
            <p class="pill-text">Een ontwerp dat bezoekers verleidt en een structuur die ze feilloos naar de contactpagina leidt.</p>
          </div>
          <div class="pill">
            <h3 class="pill-title">Technische SEO</h3>
            <p class="pill-text">Een razendsnelle basis en een structuur die Google begrijpt, zodat je ook echt gevonden wordt.</p>
          </div>
          <div class="pill">
            <h3 class="pill-title">Lokaal resultaat</h3>
            <p class="pill-text">Focus op Wageningen en de regio Foodvalley voor een sterke lokale aanwezigheid.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- COSTS -->
    <section class="section costs" aria-label="Kosten website laten maken Wageningen" id="kosten">
      <div class="container">
        <div class="section-head">
          <h2 class="h2">Wat kost een website laten maken in Wageningen?</h2>
          <p class="lead small">Helderheid vooraf. Geen verrassingen achteraf.</p>
        </div>
        <div class="costs-grid" aria-label="Investering">
          {investments.map((p) => (
            <div class="cost-card">
              <div class="cost-top">
                <div class="cost-title">{p.title}</div>
                <div class="cost-price">{p.price}</div>
              </div>
              <ul class="cost-list">
                {p.points.map((x) => <li>{x}</li>)}
              </ul>
              <p class="cost-note">{p.note}</p>
              <div class="cost-actions">
                <Button href="/contact" variant="primary" label="Vraag offerte aan" />
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CASES -->
    <section class="section" aria-label="Cases" id="cases">
      <div class="container">
        <div class="section-head">
          <h2 class="h2">Recent werk</h2>
        </div>
      </div>
      <CasesPreview />
    </section>

    <!-- FAQ -->
    <section class="section faq" aria-label="FAQ" id="faq">
      <div class="container">
        <h2 class="h2">Veelgestelde vragen</h2>
        <div class="faq-wrap">
          {faqs.map((f) => (
            <details class="faq-item">
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CONTACT CTA -->
    <section class="section contact-cta" id="contact" aria-label="Contact">
      <div class="container">
        <div class="cta-box">
          <div>
            <p class="kicker">Kennismaken</p>
            <h2 class="h2">Jouw project bespreken?</h2>
            <p class="lead small">Plan een afspraak in Wageningen of online.</p>
          </div>
          <div class="cta-actions">
            <Button href="/contact" variant="primary" label="Plan kennismaking" />
          </div>
        </div>
      </div>
    </section>
  </main>

  <style>
    .section { padding: 70px 0; }
    .container { width: min(1100px, calc(100% - 2rem)); margin: 0 auto; }
    .kicker{ text-transform: uppercase; font-size: 12px; letter-spacing: .14em; color: rgba(255,255,255,.55); margin: 0 0 10px; }
    .h1{ margin: 0; font-size: clamp(40px, 4.6vw, 68px); letter-spacing: -0.045em; line-height: 1.05; font-weight: 650; }
    .h2{ margin: 0; font-size: clamp(28px, 4vw, 42px); letter-spacing: -0.03em; line-height: 1.15; }
    .lead{ margin: 18px 0 0; color: rgba(255,255,255,.74); line-height: 1.75; font-size: 18px; max-width: 72ch; }
    .lead.small{ font-size: 16px; margin-top: 10px; max-width: 80ch; }
    .text{ margin: 14px 0 0; color: rgba(255,255,255,.68); line-height: 1.8; max-width: 80ch; }
    .inline-link{ color: rgba(47,137,255,.95); text-decoration: none; border-bottom: 1px solid rgba(47,137,255,.35); }
    .hero-simple{ padding-top: 130px; }
    .cta{ margin-top: 26px; display:flex; gap: 12px; flex-wrap: wrap; }
    .proof{ margin-top: 22px; display:flex; flex-wrap: wrap; gap: 12px; color: rgba(255,255,255,.52); font-size: 14px; }
    .sep{ opacity: .35; }
    .chips{ margin-top: 18px; display:flex; flex-wrap:wrap; gap: 10px; }
    .chip{ border: 1px solid rgba(255,255,255,.12); background: rgba(255,255,255,.03); border-radius: 999px; padding: 8px 12px; color: rgba(255,255,255,.78); font-size: 13px; }
    .pillars{ margin-top: 18px; display:grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18px; }
    .pill{ border: 1px solid rgba(255,255,255,.12); background: rgba(255,255,255,.025); border-radius: 16px; padding: 20px; }
    .pill-title{ margin: 0 0 8px; font-weight: 650; color: rgba(255,255,255,.92); font-size: 16px; }
    .pill-text{ margin: 0; color: rgba(255,255,255,.70); line-height: 1.65; font-size: 14px; }
    .costs-grid{ margin-top: 18px; display:grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }
    .cost-card{ border: 1px solid rgba(255,255,255,0.12); background: rgba(255,255,255,0.03); border-radius: 16px; padding: 18px; }
    .cost-top{ display:flex; justify-content: space-between; gap: 12px; align-items: baseline; margin-bottom: 10px; }
    .cost-title{ font-weight: 700; color: rgba(255,255,255,.92); }
    .cost-price{ color: rgba(255,255,255,.72); font-weight: 650; white-space: nowrap; }
    .cost-list{ margin: 0; padding: 0; list-style: none; display:grid; gap: 8px; }
    .cost-list li{ color: rgba(255,255,255,.72); line-height: 1.6; padding-left: 18px; position: relative; font-size: 14px; }
    .cost-list li::before{ content: "→"; position: absolute; left: 0; color: rgba(47,137,255,.95); font-weight: 700; }
    .cost-note{ margin: 12px 0 0; color: rgba(255,255,255,.62); line-height: 1.7; font-size: 14px; }
    .cost-actions{ margin-top: 14px; }
    .faq-wrap{ margin-top: 18px; display:grid; gap: 12px; }
    .faq-item{ border: 1px solid rgba(255,255,255,.12); border-radius: 14px; background: rgba(255,255,255,.025); padding: 4px 0; overflow:hidden; }
    .faq-item summary{ cursor: pointer; list-style: none; padding: 16px; font-weight: 650; color: rgba(255,255,255,.92); }
    .faq-item p{ margin: 0; padding: 0 16px 16px; color: rgba(255,255,255,.74); line-height: 1.8; }
    .cta-box{ border: 1px solid rgba(255,255,255,0.12); background: rgba(255,255,255,0.04); border-radius: 20px; padding: 22px; display:flex; gap: 18px; align-items: center; justify-content: space-between; flex-wrap: wrap; }

    @media (max-width: 900px){
      .pillars, .costs-grid, .cta-box { grid-template-columns: 1fr; }
      .hero-simple{ padding-top: 110px; }
    }
  </style>
</BaseLayout>